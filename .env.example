# ===========================================
# NEXO Frontend - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Analytics (for production)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Sentry (for production)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# RevenueCat (In-App Purchases for native platforms)
# NEXT_PUBLIC_REVENUECAT_API_KEY=your_revenuecat_ios_key_here
# NEXT_PUBLIC_REVENUECAT_ANDROID_API_KEY=your_revenuecat_android_key_here
